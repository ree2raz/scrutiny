# LLM provider: "huggingface" (default), "anthropic", "openai", or "openrouter"
LLM_PROVIDER=huggingface

# Hugging Face Inference API (default — works on HF Spaces with auto-injected HF_TOKEN)
HF_TOKEN=hf_***
HF_MODEL=google/gemma-4-31B-it

# Anthropic
ANTHROPIC_API_KEY=sk-ant-***
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=sk-***
OPENAI_MODEL=gpt-4o

# OpenRouter (alternative: set LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-***
OPENROUTER_MODEL=anthropic/claude-sonnet-4
